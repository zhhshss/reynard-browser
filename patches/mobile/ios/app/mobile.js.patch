+// REYNARD: Localization fallbacks for the iOS port.
+//
+// Gecko on iOS only ships the en-US locale package, so the default
+// `intl.accept_languages` would always be "en-US, en". We override it with a
+// pragmatic Chinese-first list with English fallback (q-values handle the
+// rest), which matches the upstream maintainer's audience and is harmless to
+// other users (servers fall back to en;q=0.7).
+//
+// `intl.regional_prefs.use_os_locales = true` makes date/number/currency
+// formatting follow the OS locale instead of the bundled locale, which is the
+// right thing to do on iOS where the user already chose a system region.
+// Combined with the LANG/LC_MESSAGES env vars exported from main.swift,
+// regional formatting effectively follows the system.
+pref("intl.accept_languages", "zh-CN,zh;q=0.9,en-US;q=0.8,en;q=0.7");
+pref("intl.regional_prefs.use_os_locales", true);
+
