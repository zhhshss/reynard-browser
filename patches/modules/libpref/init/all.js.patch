 pref("general.useragent.compatMode.firefox", false);

+// REYNARD: Reduce GeckoView logging noise because the default "Debug" level
+// just makes debugging near to impossible.
+pref("geckoview.logging", "Warn");
+
+// REYNARD: iOS scroll feel tuning. The defaults are calibrated for Android,
+// where ~60 Hz touch sampling and a different inertial model are the norm.
+// iOS users expect near-zero input latency and longer inertial coast.
+//
+// `apz.touch_move_tolerance` (default 0.1 device px): how far the finger
+//   must move before APZ accepts the gesture as a pan. Setting to 0 makes
+//   the page follow the finger instantly without a 1-frame "stick".
+// `apz.touch_start_tolerance` (default 0.1): similar, for gesture start.
+// `apz.fling_friction` (default 0.002): higher = stops faster. Lower
+//   matches iOS' long-coast feel.
+// `apz.fling_min_velocity_threshold` (default 0.5 px/ms): velocities below
+//   this don't trigger a fling at all. Lower so light flicks still coast.
+// `apz.fling_stopped_threshold` (default 0.01): below this velocity the
+//   fling is killed. Keep small so coast doesn't feel cut short.
+// `apz.frame_delay.enabled` is already false by default — leave alone.
+// `general.smoothScroll.*` keep enabled for programmatic scrolls (CSS
+//   `scroll-behavior: smooth`, anchor links, JS scrollTo).
+pref("apz.touch_move_tolerance", "0.0");
+pref("apz.touch_start_tolerance", "0.0");
+pref("apz.fling_friction", "0.0017");
+pref("apz.fling_min_velocity_threshold", "0.4");
+pref("apz.fling_stopped_threshold", "0.005");
+pref("apz.fling_curve_function_x1", "0.41");
+pref("apz.fling_curve_function_y1", "0.0");
+pref("apz.fling_curve_function_x2", "0.99");
+pref("apz.fling_curve_function_y2", "1.0");
+pref("apz.fling_curve_threshold_inches_per_ms", "0.01");
+
 pref("general.config.obscure_value", 13); // for MCD .cfg files

